{
  "name": "obsidian-easy-table",
  "version": "0.0.1",
  "private": true,
  "description": "Easy typed markdown tables for Obsidian",
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test vite.config.ts vitest.config.ts",
    "lint:fix": "eslint src test vite.config.ts vitest.config.ts --fix",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.39.1",
    "@stylistic/eslint-plugin": "^4.4.1",
    "@types/node": "^22.15.3",
    "builtin-modules": "^4.0.0",
    "eslint": "9.39.2",
    "globals": "^16.0.0",
    "obsidian": "^1.8.10",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1",
    "vite": "^7.1.5",
    "vite-plugin-static-copy": "^3.2.0",
    "vitest": "^3.1.2"
  }
}
