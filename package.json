{
  "name": "obsidian-easy-table",
  "version": "0.0.1",
  "private": true,
  "description": "Easy typed markdown tables for Obsidian",
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test vite.config.ts vitest.config.ts",
    "lint:fix": "eslint src test vite.config.ts vitest.config.ts --fix",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@stylistic/eslint-plugin": "^4.4.1",
    "@types/node": "^22.19.19",
    "builtin-modules": "^4.0.0",
    "eslint": "9.39.2",
    "globals": "^16.5.0",
    "obsidian": "^1.13.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^7.3.3",
    "vite-plugin-static-copy": "^3.4.0",
    "vitest": "^4.1.7"
  }
}
